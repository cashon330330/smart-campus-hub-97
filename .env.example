# ==============================================================================
#  SMART CAMPUS HUB — .env.example
#  ✅ Safe to commit to Git — contains placeholder values only, NO real secrets.
#
#  HOW TO USE:
#    Windows:    copy .env.example .env
#    Mac/Linux:  cp .env.example .env
#    Then replace each placeholder with your real Supabase credentials.
# ==============================================================================


# ------------------------------------------------------------------------------
# Supabase Public/Client Configuration
# (VITE_ prefix exposes these to the browser via Vite)
# 📍 Get from: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------------------

# Your Supabase project API URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your Supabase public anonymous API key
# (Project Settings → API → Project API Keys → anon public)
# ✅ Safe in browser — protected by Row Level Security (RLS)
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY


# ------------------------------------------------------------------------------
# Supabase Server-Only Configuration
# (DO NOT prefix with VITE_ — must never reach the browser)
# 📍 Get from: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------------------

# Service Role Key — used for admin / bypass-RLS actions
# (Project Settings → API → Project API Keys → service_role)
# 🔴 NEVER expose this to the client!
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Alias used by setup_supabase_tables.js  (maps to same service_role key above)
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY


# ------------------------------------------------------------------------------
# Database Connection Strings
# (Used by ORMs like Prisma / Drizzle or direct postgres drivers)
# 📍 Get from: Supabase Dashboard → Project Settings → Database
#              → Connection string → URI tab
#    Replace [YOUR-PASSWORD] with your database password.
# ------------------------------------------------------------------------------

# Transaction Pooler — port 6543
# ✅ Use for app queries, serverless functions, Prisma at runtime
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_ID:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Session / Direct connection — port 5432
# ⚠️  Use only for running migrations (bypasses the pooler)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_ID:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres


# ------------------------------------------------------------------------------
# App Configuration
# ------------------------------------------------------------------------------

VITE_APP_ENV=development
VITE_APP_NAME=Smart Campus Hub
