# Your Supabase public anonymous API key
# (Project Settings → API → Project API Keys → anon public)
# ✅ Safe in browser — protected by Row Level Security (RLS)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ3ZG5mZW9ld2x2ZWxzY3BkY2NuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIxMzA4MzQsImV4cCI6MjA5NzcwNjgzNH0.UPx7cz2nya6K3eSHB9IvSevLa-ljWxZoaCrhau-Kdiw


# ------------------------------------------------------------------------------
# Supabase Server-Only Configuration
# (DO NOT prefix with VITE_ — must never reach the browser)
# 📍 Get from: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------------------

# Service Role Key — used for admin / bypass-RLS actions
# (Project Settings → API → Project API Keys → service_role)
# 🔴 NEVER expose this to the client!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ3ZG5mZW9ld2x2ZWxzY3BkY2NuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MjEzMDgzNCwiZXhwIjoyMDk3NzA2ODM0fQ.1PB7DRIVMQRm3lVVrsZlyKk_Nr4ci4F1V8JRuQfdEII

